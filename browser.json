{
  "chromium": {
    "description": "Open-source browser engine. Snapshot builds by revision number.",
    "revision": {
      "default": 1588893,
      "playwright_arm64": 1124,
      "latest_api": {
        "windows_amd64": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/Win_x64/LAST_CHANGE",
        "linux_amd64": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/Linux_x64/LAST_CHANGE",
        "linux_arm64": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/Linux_x64/LAST_CHANGE",
        "darwin_amd64": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/Mac/LAST_CHANGE",
        "darwin_arm64": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/Mac_Arm/LAST_CHANGE"
      }
    },
    "hosts": {
      "google": {
        "base": "https://storage.googleapis.com/chromium-browser-snapshots",
        "pattern": "{base}/{prefix}/{revision}/{zip}",
        "index": "https://commondatastorage.googleapis.com/chromium-browser-snapshots/index.html"
      },
      "npmmirror": {
        "base": "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots",
        "pattern": "{base}/{prefix}/{revision}/{zip}"
      },
      "playwright": {
        "base": "https://playwright.azureedge.net/builds/chromium",
        "pattern": "{base}/{revision}/chromium-linux-arm64.zip",
        "note": "Only used for linux_arm64 with RevisionPlaywright"
      }
    },
    "platforms": {
      "windows_amd64": {
        "prefix": "Win_x64",
        "zip": "chrome-win.zip",
        "binary": "chrome-win/chrome.exe",
        "urls": [
          "https://storage.googleapis.com/chromium-browser-snapshots/Win_x64/{revision}/chrome-win.zip",
          "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots/Win_x64/{revision}/chrome-win.zip"
        ]
      },
      "windows_386": {
        "prefix": "Win",
        "zip": "chrome-win.zip",
        "binary": "chrome-win/chrome.exe",
        "urls": [
          "https://storage.googleapis.com/chromium-browser-snapshots/Win/{revision}/chrome-win.zip",
          "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots/Win/{revision}/chrome-win.zip"
        ]
      },
      "linux_amd64": {
        "prefix": "Linux_x64",
        "zip": "chrome-linux.zip",
        "binary": "chrome-linux/chrome",
        "urls": [
          "https://storage.googleapis.com/chromium-browser-snapshots/Linux_x64/{revision}/chrome-linux.zip",
          "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots/Linux_x64/{revision}/chrome-linux.zip"
        ]
      },
      "linux_arm64": {
        "prefix": "Linux_x64",
        "zip": "chromium-linux-arm64.zip",
        "binary": "chrome-linux/chrome",
        "urls": [
          "https://playwright.azureedge.net/builds/chromium/{playwright_revision}/chromium-linux-arm64.zip"
        ],
        "note": "Uses RevisionPlaywright (1124), not RevisionDefault"
      },
      "darwin_amd64": {
        "prefix": "Mac",
        "zip": "chrome-mac.zip",
        "binary": "chrome-mac/Chromium.app/Contents/MacOS/Chromium",
        "urls": [
          "https://storage.googleapis.com/chromium-browser-snapshots/Mac/{revision}/chrome-mac.zip",
          "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots/Mac/{revision}/chrome-mac.zip"
        ]
      },
      "darwin_arm64": {
        "prefix": "Mac_Arm",
        "zip": "chrome-mac.zip",
        "binary": "chrome-mac/Chromium.app/Contents/MacOS/Chromium",
        "urls": [
          "https://storage.googleapis.com/chromium-browser-snapshots/Mac_Arm/{revision}/chrome-mac.zip",
          "https://registry.npmmirror.com/-/binary/chromium-browser-snapshots/Mac_Arm/{revision}/chrome-mac.zip"
        ]
      }
    }
  },
