{
  "version": "1",
  "name": "gmaps_search",
  "type": "extract",
  "url": "https://www.google.com/maps/search/{{query}}",
  "wait_for": "[role=\"article\"]",
  "items": {
    "container": "[role=\"article\"]",
    "fields": {
      "name": "[aria-label]@aria-label",
      "rating": ".fontBodyMedium span[aria-hidden]",
      "address": ".fontBodyMedium > div:last-child"
    }
  },
  "output": {
    "format": "json"
  }
}
