{
  "version": "1",
  "name": "Slack Messages",
  "type": "automate",
  "steps": [
    {"action": "navigate", "url": "https://{{workspace}}.slack.com"},
    {"action": "type", "selector": "input[data-qa=\"login_email\"]", "text": "{{username}}"},
    {"action": "type", "selector": "input[data-qa=\"login_password\"]", "text": "{{password}}"},
    {"action": "click", "selector": "[data-qa=\"signin_button\"]"},
    {"action": "wait", "selector": "[data-qa=\"channel_sidebar_name\"]"},
    {"action": "navigate", "url": "https://{{workspace}}.slack.com/archives/{{channel_id}}"},
    {"action": "wait", "selector": "[data-qa=\"message_container\"]"},
    {
      "action": "extract",
      "selector": "[data-qa=\"message_container\"]",
      "name": "messages",
      "items": {
        "container": "[data-qa=\"message_container\"]",
        "fields": {
          "sender": "[data-qa=\"message_sender_name\"]",
          "text": "[data-qa=\"message-text\"]"
        }
      }
    }
  ],
  "output": {"format": "json"}
}
