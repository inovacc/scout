{
  "name": "scout-network",
  "version": "1.0.0",
  "description": "Network inspection tools: cookie, header, block, storage, hijack, HAR, Swagger",
  "author": "inovacc",
  "command": "scout-network",
  "capabilities": ["mcp_tool"],
  "tools": [
    {"name": "cookie", "description": "Manage browser cookies (get, set, delete)", "inputSchema": {"type": "object", "properties": {"url": {"type": "string"}, "action": {"type": "string", "enum": ["get", "set", "delete"]}, "name": {"type": "string"}, "value": {"type": "string"}}}},
    {"name": "header", "description": "Set custom headers for all requests", "inputSchema": {"type": "object", "properties": {"headers": {"type": "object", "additionalProperties": {"type": "string"}}}, "required": ["headers"]}},
    {"name": "block", "description": "Block requests matching URL patterns", "inputSchema": {"type": "object", "properties": {"patterns": {"type": "array", "items": {"type": "string"}}}, "required": ["patterns"]}},
    {"name": "storage", "description": "Manage localStorage and sessionStorage", "inputSchema": {"type": "object", "properties": {"type": {"type": "string", "enum": ["local", "session"]}, "action": {"type": "string", "enum": ["get", "set", "clear"]}, "key": {"type": "string"}, "value": {"type": "string"}}}},
    {"name": "hijack", "description": "Start/stop real-time HTTP traffic interception", "inputSchema": {"type": "object", "properties": {"action": {"type": "string", "enum": ["start", "stop", "status"]}, "filter": {"type": "string"}}}},
    {"name": "har", "description": "Manage HAR network recording", "inputSchema": {"type": "object", "properties": {"action": {"type": "string", "enum": ["start", "stop", "export"]}, "path": {"type": "string"}}}},
    {"name": "swagger", "description": "Detect and extract Swagger/OpenAPI spec from a page", "inputSchema": {"type": "object", "properties": {"url": {"type": "string"}}, "required": ["url"]}}
  ]
}
